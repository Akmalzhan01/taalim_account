PORT=5000
NODE_ENV=development

# Строка подключения: локальная MongoDB или Atlas.
# ВАЖНО: обязательно укажите имя базы после хоста (здесь — /account),
# иначе всё запишется в служебную базу test.
MONGO_URI=mongodb://127.0.0.1:27017/account

# JWT — в продакшене замените на длинную случайную строку
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

CLIENT_URL=http://localhost:5173
